{
  "id": null,
  "uid": "darknoc-langfuse-ops",
  "title": "Langfuse Operations",
  "tags": ["dark-noc", "langfuse", "tracing", "ops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "style": "dark",
  "time": {"from": "now-12h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Langfuse Pods Ready",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(kube_pod_status_ready{namespace=\"dark-noc-observability\",condition=\"true\",pod=~\"langfuse-.*\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Langfuse Restarts (24h)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\"}[24h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Langfuse CPU (cores)",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\",container!=\"\",image!=\"\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cores", "decimals": 2}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Langfuse Memory",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(container_memory_working_set_bytes{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\",container!=\"\",image!=\"\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Langfuse CPU by Pod",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\",container!=\"\",image!=\"\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cores"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Langfuse Memory by Pod",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\",container!=\"\",image!=\"\"})", "legendFormat": "{{pod}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Langfuse Network In/Out",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(container_network_receive_bytes_total{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\"}[5m]))", "legendFormat": "ingress", "refId": "A"},
        {"expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"dark-noc-observability\",pod=~\"langfuse-.*\"}[5m]))", "legendFormat": "egress", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ]
}
