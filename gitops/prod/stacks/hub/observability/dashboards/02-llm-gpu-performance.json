{
  "id": null,
  "uid": "darknoc-llm-gpu",
  "title": "LLM + GPU Performance",
  "tags": ["dark-noc", "llm", "gpu", "rhoai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "style": "dark",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Inference Pods Ready",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(kube_pod_status_ready{namespace=~\"dark-noc-hub|my-first-model\",condition=\"true\",pod=~\".*predictor.*|.*llama.*|.*vllm.*\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Token Throughput / sec",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(vllm_generation_tokens_total[5m])) or sum(rate(vllm:tokens_generated_total[5m])) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 Inference Latency",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm_request_latency_seconds_bucket[5m]))) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU Utilization by Device",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}} @ {{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU Memory Utilization by Device",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 * (DCGM_FI_DEV_FB_USED / clamp_min(DCGM_FI_DEV_FB_TOTAL, 1))", "legendFormat": "GPU {{gpu}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GPU Power Draw",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "GPU {{gpu}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "watt"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GPU Temperature",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "DCGM_FI_DEV_GPU_TEMP", "legendFormat": "GPU {{gpu}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "celsius"}}
    }
  ]
}
