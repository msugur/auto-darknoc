#!/usr/bin/env bash
# =============================================================
# Dark NOC — Edge Cluster Environment Variables
# =============================================================
# Source this when working on edge cluster tasks:
#   source configs/edge/env.sh
# =============================================================

# ---- Edge Cluster Access ----
export EDGE_API_URL="https://<edge-api-server>:6443"
export EDGE_TOKEN="<your-edge-01-admin-token>"
export EDGE_CONTEXT="<edge-kubeconfig-context-name>"
export EDGE_CLUSTER_NAME="edge-01"
export EDGE_APPS_DOMAIN="apps.<edge-01-domain>"

# ---- Hub Kafka endpoint (edge sends logs here) ----
export HUB_KAFKA_BOOTSTRAP_TLS="dark-noc-kafka-kafka-bootstrap.<hub-apps-domain>:443"
export KAFKA_TOPIC_LOGS="edge.logs.raw"

# ---- Edge Workloads ----
export EDGE_NAMESPACE="dark-noc-edge"
export NGINX_DEPLOYMENT="nginx-webserver"

# ---- ACM Hub reference ----
export ACM_HUB_URL="https://<hub-api-server>:6443"

echo "✅ Edge environment loaded"
echo "   Edge API:   ${EDGE_API_URL}"
echo "   Edge Site:  ${EDGE_CLUSTER_NAME}"
