#!/usr/bin/env bash
# Minimal required inputs for one-click deploy.
# Copy to configs/hub/env.sh and fill values.

# Required: hub cluster
export HUB_API_URL="https://api.ocp.<hub-guid>.<domain>:6443"
# Use either token OR username/password
export HUB_TOKEN=""
export HUB_USERNAME="admin"
export HUB_PASSWORD="<hub-admin-password>"
export HUB_CONTEXT="hub"
export HUB_CLUSTER_NAME="hub-cluster"

# Required: edge cluster
export EDGE_API_URL="https://api.ocp.<edge-guid>.<domain>:6443"
# Use either token OR username/password
export EDGE_TOKEN=""
export EDGE_USERNAME="admin"
export EDGE_PASSWORD="<edge-admin-password>"
export EDGE_CONTEXT="edge"
export EDGE_CLUSTER_NAME="edge-01"

# Required: ServiceNow instance
export SNOW_URL="https://<instance>.service-now.com"

# Optional (defaults used if omitted)
export SNOW_USERNAME="admin"
export SNOW_PASSWORD="<your-servicenow-password>"
export SLACK_WORKSPACE_URL="https://octo-emerging-tech.slack.com"
export SLACK_BOT_TOKEN="xoxb-<your-slack-bot-token>"
export SLACK_NOC_CHANNEL="#demos"
export HUB_APPS_DOMAIN="apps.ocp.<hub-guid>.<domain>"
export EDGE_APPS_DOMAIN="apps.ocp.<edge-guid>.<domain>"

# Optional if private Quay images are used with --create-quay-pull
# export QUAY_USERNAME="<quay-user-or-robot>"
# export QUAY_TOKEN="<quay-token>"
# export QUAY_EMAIL="admin@example.com"

echo "✅ Hub environment loaded"
echo "   Hub API: ${HUB_API_URL}"
