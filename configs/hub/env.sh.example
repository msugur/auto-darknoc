#!/usr/bin/env bash
# =============================================================
# Dark NOC — Hub Cluster Environment Variables
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp env.sh.example env.sh
#   2. Fill in all values below
#   3. Source before running any commands: source configs/hub/env.sh
#   4. NEVER commit env.sh to git (it is gitignored)
# =============================================================

# ---- Hub Cluster Access ----
export HUB_API_URL="https://<hub-api-server>:6443"
export HUB_TOKEN="<your-hub-cluster-admin-token>"
export HUB_CONTEXT="<hub-kubeconfig-context-name>"
export HUB_CLUSTER_NAME="hub-cluster"
export HUB_APPS_DOMAIN="apps.<hub-cluster-domain>"

# ---- Edge Cluster Access ----
export EDGE_API_URL="https://<edge-api-server>:6443"
export EDGE_TOKEN="<your-edge-01-admin-token>"
export EDGE_CONTEXT="<edge-kubeconfig-context-name>"
export EDGE_CLUSTER_NAME="edge-01"
export EDGE_APPS_DOMAIN="apps.<edge-01-domain>"

# ---- AWS Region ----
export AWS_REGION="us-east-1"
export AWS_AVAILABILITY_ZONE="us-east-1a"   # Zone where GPU instance will be added

# ---- MinIO (deployed on hub cluster) ----
export MINIO_ENDPOINT="http://minio.dark-noc-minio.svc:9000"
export MINIO_ACCESS_KEY="darknoc-minio-admin"
export MINIO_SECRET_KEY="<generate-strong-password>"
export MINIO_BUCKET_MODELS="rhoai-models"
export MINIO_BUCKET_LOKI="loki-chunks"
export MINIO_BUCKET_LANGFUSE="langfuse-data"

# ---- Slack Integration ----
export SLACK_BOT_TOKEN="<your-slack-bot-token>"
export SLACK_NOC_CHANNEL="#dark-noc-alerts"
export SLACK_CHANNEL_ID="<your-channel-id>"

# ---- Langfuse Observability ----
export LANGFUSE_HOST="https://langfuse.${HUB_APPS_DOMAIN}"
export LANGFUSE_PUBLIC_KEY="<generated-after-langfuse-setup>"
export LANGFUSE_SECRET_KEY="<generated-after-langfuse-setup>"

# ---- AAP (Ansible Automation Platform) ----
export AAP_URL="https://aap-controller.${HUB_APPS_DOMAIN}"
export AAP_USERNAME="admin"
export AAP_TOKEN="<generated-after-aap-setup>"
export AAP_JOB_TEMPLATE_ID="42"   # Updated after template creation

# ---- ServiceNow Mock ----
export SNOW_URL="https://servicenow-mock.${HUB_APPS_DOMAIN}"
export SNOW_USERNAME="admin"
export SNOW_PASSWORD="mock-password"

# ---- LlamaStack ----
export LLAMA_STACK_URL="http://dark-noc-llama-stack.dark-noc-hub.svc:5000"
export VLLM_URL="http://granite-h-tiny-predictor.dark-noc-hub.svc:8080"
export MODEL_ID="granite-4.0-h-tiny"
# Model profile used by scripts/render-model-profile.sh
export MODEL_PROFILE="granite-4-h-tiny"

# ---- Kafka ----
export KAFKA_BOOTSTRAP="dark-noc-kafka-kafka-bootstrap.dark-noc-kafka.svc:9092"
export KAFKA_BOOTSTRAP_TLS="dark-noc-kafka-kafka-bootstrap.dark-noc-kafka.svc:9093"
export KAFKA_TOPIC_LOGS="edge.logs.raw"
export KAFKA_TOPIC_ALERTS="edge.alerts.classified"
export KAFKA_TOPIC_REMEDIATION="edge.remediation.actions"
export KAFKA_TOPIC_RESULTS="edge.remediation.results"
export KAFKA_TOPIC_TRACE="noc.agent.trace"

# ---- pgvector RAG ----
export PGVECTOR_URL="postgresql://llama:changeme@pgvector-rag-rw.dark-noc-rag.svc:5432/llamastack"

# ---- Derived (optional defaults) ----
if [[ -z "${HUB_CONTEXT}" ]]; then
  HUB_CONTEXT="$(oc config current-context 2>/dev/null || true)"
fi
echo "✅ Hub environment loaded"
echo "   Hub API:  ${HUB_API_URL}"
echo "   Region:   ${AWS_REGION}"
echo "   Model:    ${MODEL_ID}"
